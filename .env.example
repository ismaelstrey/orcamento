NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orcamento
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/orcamento

JWT_ACCESS_SECRET=change-me-with-at-least-32-characters
JWT_REFRESH_SECRET=change-me-too-with-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12

REDIS_URL=redis://localhost:6379

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: habilita o assistente de IA para gerar JSON revisavel de orcamento.
# Valores aceitos: local, openai, gemini. Use lista para fallback: openai,local ou gemini,local.
AI_QUOTE_DRAFT_PROVIDER=local

# Provider OpenAI opcional. Nao versionar chave real.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_INPUT_COST_CENTS_PER_1K=
# OPENAI_OUTPUT_COST_CENTS_PER_1K=

# Provider Gemini opcional. Nao versionar chave real.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_INPUT_COST_CENTS_PER_1K=
# GEMINI_OUTPUT_COST_CENTS_PER_1K=

BOOTSTRAP_TENANT_NAME=Bootstrap Tenant
BOOTSTRAP_TENANT_SLUG=bootstrap-tenant
BOOTSTRAP_OWNER_NAME=Owner Bootstrap
BOOTSTRAP_OWNER_EMAIL=owner@bootstrap.local
BOOTSTRAP_OWNER_PASSWORD=ChangeMe123456!
