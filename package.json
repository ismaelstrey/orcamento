{
  "name": "orcamento",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "corepack pnpm --filter web dev",
    "build": "corepack pnpm -r --if-present build",
    "lint": "corepack pnpm --filter web lint",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "test": "corepack pnpm -r --if-present test",
    "db:generate": "corepack pnpm exec prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "corepack pnpm exec prisma migrate dev --schema ./prisma/schema.prisma",
    "db:seed": "corepack pnpm exec tsx prisma/seed.ts"
  },
  "dependencies": {
    "@orcamento/auth": "workspace:*",
    "@prisma/client": "^6.16.3",
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "prisma": "^6.16.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  }
}
